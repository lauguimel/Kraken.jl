# Lid-driven cavity Re=100 on 64x64 grid
# Gerris 2D simulation file
#
# Domain: single GfsBox [-0.5, 0.5]^2
# Refine 6 => 2^6 = 64 cells per dimension
# Re = U*L/nu = 1*1/0.01 = 100
# Top lid (y=0.5): u=1, v=0
# Other walls: no-slip (default)

1 0 GfsSimulation GfsBox GfsGEdge {} {
    Refine 6

    # Kinematic viscosity nu = 1/Re = 0.01
    SourceViscosity 0.01

    # Run to steady state
    Time { end = 50 dtmax = 0.01 }

    # Progress reporting to stderr
    OutputTime { istep = 1000 } stderr
    OutputProjectionStats { istep = 1000 } stderr

    # Lid velocity: u=1 at top wall (y ~ 0.5), no-slip elsewhere
    SurfaceBc U Dirichlet (y > 0.49999 ? 1. : 0.)
    SurfaceBc V Dirichlet 0.

    # Output u-velocity along vertical centerline (x=0 in Gerris domain)
    # Sample 64 points from y=-0.5 to y=0.5
    OutputLocation { start = end } results/cavity_profile.dat centerline.txt

    # Output timing information
    OutputTiming { start = end } stderr
}
GfsBox {}
